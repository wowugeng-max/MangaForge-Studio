# Provider selection
# openai-compatible | qwen-compatible | anthropic-compatible | custom-openai-compatible
LLM_PROVIDER=custom-openai-compatible

# Custom OpenAI-compatible provider (used by CLIProxyAPI or any OpenAI-style gateway)
LLM_CUSTOM_ENDPOINT=https://api.aicomic.site/v1
LLM_CUSTOM_API_KEY=your_api_key_here
LLM_CUSTOM_MODEL=gpt-5.4

# Anthropic / Claude Code style proxy
ANTHROPIC_BASE_URL=http://127.0.0.1:8317
ANTHROPIC_AUTH_TOKEN=sk-dummy
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-1-20250805
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-3-5-haiku-20241022

# Optional legacy compatibility endpoints
LLM_OPENAI_ENDPOINT=https://api.openai.com/v1
LLM_GEMINI_ENDPOINT=http://localhost:3001/llm
LLM_QWEN_ENDPOINT=http://localhost:3001/llm
